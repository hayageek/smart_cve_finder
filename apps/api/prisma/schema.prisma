generator client {
  provider      = "prisma-client-js"
  // Workers runtime image is Alpine (musl); API stays on Debian (glibc).
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Repo {
  id             String    @id @default(cuid())
  // Canonical unique key per scannable artifact:
  //   git repos  → clone URL as-is   e.g. https://github.com/org/repo
  //   packages   → {type}:{name}     e.g. npm:express
  //              → {type}:{name}@{v} e.g. npm:express@4.17.21  (version-pinned)
  //                                       pip:requests@2.31.0
  url            String    @unique
  // Discovered git repository URL from npm/pip registry metadata (null for git repos)
  repoUrl        String?
  // Package tarball download URL from npm/pip registry (null for git repos)
  tarballUrl     String?
  // Package-specific fields (null for git repos)
  packageName    String?
  packageType    String    @default("git")   // git | npm | pip | cargo | go | gem
  packageVersion String?                     // resolved version after download
  provider       String    // github | bitbucket | gitlab | npm | pypi | other
  isPrivate      Boolean   @default(false)
  githubStars              Int?
  githubForks              Int?
  privateVulnerabilityReportingEnabled Boolean?
  status         String    @default("queued")
  lastScannedAt  DateTime?
  // Last successfully scanned git commit SHA or package version string.
  lastScannedRevision String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  scanJobs       ScanJob[]

  @@index([status])
  @@index([packageType])
  @@index([provider])
  @@index([isPrivate])
}

model ScanJob {
  id           String          @id @default(cuid())
  repoId       String
  repo         Repo            @relation(fields: [repoId], references: [id], onDelete: Cascade)
  bullJobId    String?
  status       String          @default("pending")
  stage        String?
  // cve | secrets | both
  scanMode     String          @default("both")
  startedAt    DateTime?
  finishedAt   DateTime?
  error        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  vulnerabilities Vulnerability[]
  secrets         Secret[]

  @@index([repoId])
  @@index([status])
  @@index([createdAt])
}

model Vulnerability {
  id              String    @id
  scanJobId       String
  scanJob         ScanJob   @relation(fields: [scanJobId], references: [id], onDelete: Cascade)
  checkId         String
  path            String
  lineStart       Int
  lineEnd         Int?
  severity        String
  severityRank    Int       @default(0)
  cwe             String
  vulnType        String?
  message         String?
  metadataJson    Json?
  isFalsePositive Boolean   @default(false)
  // Marked complete — reported/disclosed as CVE
  cveReported     Boolean   @default(false)
  cveReportedAt   DateTime?
  cvssScore       Float?

  // dropped=true when the CVE hunter intentionally excluded this finding
  dropped         Boolean   @default(false)
  dropReason      String?
  dropEvidence    String?

  // exploit lifecycle — null means not yet attempted
  exploitStatus   String?   // pending | generating | done | failed
  reportPath      String?
  exploitPath     String?
  payloadPath     String?
  exploitError    String?
  exploitAttempts Int?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([scanJobId])
  @@index([severity])
  @@index([severityRank])
  @@index([cwe])
  @@index([isFalsePositive])
  @@index([dropped])
  @@index([exploitStatus])
  @@index([cveReported])
}

model Secret {
  id              String    @id
  scanJobId       String
  scanJob         ScanJob   @relation(fields: [scanJobId], references: [id], onDelete: Cascade)
  ruleId          String
  path            String
  lineStart       Int
  lineEnd         Int?
  severity        String
  severityRank    Int       @default(0)
  secretType      String?
  redactedValue   String?
  verifyStatus    String    @default("unverified")
  detectorName    String?
  message         String?
  metadataJson    Json?
  isFalsePositive Boolean   @default(false)
  dropped         Boolean   @default(false)
  dropReason      String?
  dropEvidence    String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([scanJobId])
  @@index([severity])
  @@index([severityRank])
  @@index([verifyStatus])
  @@index([isFalsePositive])
  @@index([dropped])
}

model WorkerConfig {
  id                    String   @id @default(cuid())
  scannerConcurrency    Int      @default(3)
  exploitConcurrency    Int      @default(2)
  // When false, findings are saved but NOT automatically queued for exploitation.
  // Queue manually from the dashboard. When true, auto-queue findings at or above exploitMinSeverity.
  autoQueueExploits     Boolean  @default(true)
  exploitMinSeverity    String   @default("CRITICAL")
  exploitIncludeDropped Boolean  @default(false)
  dedupWindowHours      Int      @default(24)
  workspaceCleanupHours Int      @default(48)
  notifyWebhookUrl      String?
  notifyOnCritical      Boolean  @default(true)
  notifyOnScanComplete  Boolean  @default(false)
  updatedAt             DateTime @updatedAt
}
