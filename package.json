{
  "name": "secscan",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "top_packages",
    "bugbounty-repos"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:workers": "npm run dev --workspace=apps/workers",
    "dev:ui": "npm run dev --workspace=apps/ui",
    "build": "npm run build --workspaces --if-present",
    "db:migrate": "node apps/api/scripts/migrate-deploy.mjs",
    "db:generate": "npm run db:generate --workspace=apps/api",
    "db:push": "node --env-file=.env ./node_modules/.bin/prisma db push --schema=apps/api/prisma/schema.prisma",
    "scan": "npm run cli --workspace=apps/workers --",
    "cli": "npm run cli --workspace=apps/workers --",
    "npm-packages": "npm run npm-packages --workspace=apps/workers --",
    "github-pvr": "npm run github-pvr --workspace=apps/workers --",
    "top-packages": "npm run cli --workspace=@secscan/top-packages --",
    "bugbounty-repos": "npm run cli --workspace=@secscan/bugbounty-repos --"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "prisma": "5.22.0",
    "@prisma/client": "5.22.0"
  }
}
