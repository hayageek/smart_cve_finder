# ── Infrastructure ──────────────────────────────────────────────
# Host commands (npm run db:push, local dev): use localhost
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=secscan
POSTGRES_USER=secscan
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://secscan:changeme@localhost:5432/secscan

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── API Server ───────────────────────────────────────────────────
# UI is served by Docker on this host port (avoid 5000 on macOS — AirPlay uses it)
UI_PORT=3000
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000

# ── MCP (Cursor / Claude IDE integration) ─────────────────────────
MCP_ENABLED=true
MCP_API_KEY=change-me-to-a-long-random-secret
MCP_PATH=/mcp
# URL IDEs use to reach MCP (shown in Settings → MCP Integration)
MCP_PUBLIC_URL=http://localhost:4000
MCP_SERVER_NAME=secscan

# ── File Paths (mounted volumes) ─────────────────────────────────
WORKSPACES_DIR=./data/workspaces
REPORTS_DIR=/data/atlassian_reports
LOGS_DIR=./data/logs
# Path to pre-cloned security_skills repo (must contain cve-pattern-hunter/ and exploit-generator/).
# In Docker: mounted as /data/skills from ./skills on the host.
# Locally (CLI): defaults to ./skills relative to the repo root.
# If not present, falls back to cloning SKILLS_REPO_URL.
SKILLS_DIR=/data/skills
SKILLS_REPO_URL=https://github.com/hayageek/security_skills

# ── Cursor SDK (@cursor/sdk) ─────────────────────────────────────
# No binary installation required — @cursor/sdk is an npm dependency.
# Get your API key from https://cursor.com/settings
CURSOR_API_KEY=
CURSOR_AGENT_TIMEOUT_MS=300000
# Model ID passed to Agent.create(). Use "composer-2.5" or a specific ID.
CURSOR_AGENT_MODEL=claude-sonnet-4-5
# Composer 2.5 tier: false = standard (cheaper), true = fast (SDK default when omitted)
CURSOR_AGENT_MODEL_FAST=false
# Set to true to log full SDK output text in worker logs
DEBUG_CURSOR=true
# Ripgrep sink prefilter before cve-pattern-hunter (requires `rg` on PATH / in Docker image)
CVE_PREFILTER_ENABLED=true
CVE_PREFILTER_RIPGREP_BIN=rg
# Semgrep candidate gate before cve-pattern-hunter (requires `semgrep` on PATH)
CVE_SEMGREP_ENABLED=true
# Local macOS (Homebrew): /opt/homebrew/bin/semgrep — Docker worker image sets PATH automatically
CVE_SEMGREP_BIN=semgrep
# CVE_SEMGREP_JOBS=4

# ── Scanner Worker ───────────────────────────────────────────────
SCANNER_CONCURRENCY=3
SCANNER_MAX_ATTEMPTS=2
SCANNER_BACKOFF_DELAY_MS=10000
SCAN_DEDUP_WINDOW_HOURS=24
WORKSPACE_CLEANUP_AFTER_HOURS=48

# ── Secret scan ──────────────────────────────────────────────────
# Minimum severity to keep from gitleaks/trufflehog gate (CRITICAL|HIGH|MEDIUM|LOW).
# MEDIUM = keep CRITICAL, HIGH, MEDIUM; drop LOW-only candidates.
SECRET_MIN_SEVERITY=MEDIUM
# When true, skip the Cursor triage skill (gitleaks + trufflehog only).
# Unverified candidates are kept as findings instead of being AI-triaged.
SECRET_GATE_ONLY=false
# When true, mask secrets in DB/UI (set false to store and show full values).
SECRET_REDACT=false

# ── Exploit Worker ───────────────────────────────────────────────
EXPLOIT_CONCURRENCY=2
EXPLOIT_MAX_ATTEMPTS=2
EXPLOIT_BACKOFF_DELAY_MS=10000
EXPLOIT_MIN_SEVERITY=HIGH
EXPLOIT_INCLUDE_DROPPED=false

# ── GitHub ───────────────────────────────────────────────────────
# Optional; improves rate limits and enables private repo metadata/PVR checks
GITHUB_TOKEN=
# Skip scanning GitHub repos below this star count (0 = disabled)
SCAN_MIN_STARS=100
# When true, only scan GitHub repos with "Report a vulnerability" (PVR) enabled
SCAN_REQUIRE_PVR=false

# ── Git ──────────────────────────────────────────────────────────
GIT_CLONE_DEPTH=1

# ── Notifications (optional) ─────────────────────────────────────
NOTIFY_WEBHOOK_URL=
NOTIFY_ON_CRITICAL=true
NOTIFY_ON_SCAN_COMPLETE=false

# ── UI (build-time, prefixed VITE_) ──────────────────────────────
# Empty = same-origin via UI proxy (Docker nginx or Vite dev server). Direct API: http://localhost:4000
VITE_API_BASE_URL=
VITE_SOCKET_URL=
