# Get a key at https://libraries.io/account (required for --recent on npm/go/ruby)
LIBRARIES_IO_KEY=

# Optional: min ms between libraries.io requests (default 1350 ≈ 44/min, limit is 50/min)
# LIBRARIES_IO_DELAY_MS=1350

# Optional: parallel PyPI/Packagist/crates.io metadata fetches (default 3)
# ENRICH_CONCURRENCY=3
