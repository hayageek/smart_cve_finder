# ── Infrastructure ──────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=secscan
POSTGRES_USER=secscan
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://secscan:changeme@localhost:5432/secscan

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── API Server ───────────────────────────────────────────────────
UI_PORT=3001
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── File Paths (mounted volumes) ─────────────────────────────────
WORKSPACES_DIR=./data/workspaces
REPORTS_DIR=./data/atlassian_reports
LOGS_DIR=./data/logs
# Local pre-cloned skills directory (mounted into Docker at /data/skills)
SKILLS_DIR=skills
SKILLS_REPO_URL=https://github.com/hayageek/security_skills

# ── Cursor SDK (@cursor/sdk) ─────────────────────────────────────
# Get your API key from https://cursor.com/settings
CURSOR_API_KEY=crsr_ea59ea16961b08bd91f4f27bd173f8e770f41f30b4ad387b859ca0e9a3cf6d18
CURSOR_AGENT_TIMEOUT_MS=300000
# Model ID passed to Agent.prompt(); use "composer-latest" or a specific model ID
CURSOR_AGENT_MODEL=composer-2.5
#CURSOR_AGENT_MODEL=claude-sonnet-4-5
# Set to true to log full SDK output text
DEBUG_CURSOR=true

# ── Scanner Worker ───────────────────────────────────────────────
SCANNER_CONCURRENCY=3
SCANNER_MAX_ATTEMPTS=2
SCANNER_BACKOFF_DELAY_MS=10000
SCAN_DEDUP_WINDOW_HOURS=24
WORKSPACE_CLEANUP_AFTER_HOURS=48

# ── Exploit Worker ───────────────────────────────────────────────
EXPLOIT_CONCURRENCY=2
EXPLOIT_MAX_ATTEMPTS=2
EXPLOIT_BACKOFF_DELAY_MS=10000
EXPLOIT_MIN_SEVERITY=HIGH
EXPLOIT_INCLUDE_DROPPED=false

# ── Git ──────────────────────────────────────────────────────────
GIT_CLONE_DEPTH=1

# ── Notifications (optional) ─────────────────────────────────────
NOTIFY_WEBHOOK_URL=
NOTIFY_ON_CRITICAL=true
NOTIFY_ON_SCAN_COMPLETE=false

# ── UI (build-time, prefixed VITE_) ──────────────────────────────
# Leave empty when using Docker UI (requests go via nginx on :3000 → api:4000).
# Set to http://localhost:4000 only if the UI calls the API directly (no proxy).
VITE_API_BASE_URL=
VITE_SOCKET_URL=


MCP_API_KEY=sk-proj-65071627-0000-0000-0000-1131331313
MCP_ENABLED=true
MCP_PUBLIC_URL=http://localhost:4000
MCP_PATH=/mcp
MCP_SERVER_NAME=secscan


CVE_PREFILTER_ENABLED=true
CVE_PREFILTER_RIPGREP_BIN=rg